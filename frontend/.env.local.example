# API REST de DocuMente — apunta al backend FastAPI corriendo localmente.
# El default si no se setea es http://localhost:8001 (igual que el dev script).
NEXT_PUBLIC_API_URL=http://localhost:8001

# Bearer token opcional. Solo necesario si el backend tiene
# DOCUMENTE_GATE_PASSWORD definida; en dev local típicamente queda vacío.
NEXT_PUBLIC_API_TOKEN=
