# DocuMente — variables de entorno
# Copia este archivo a `.env` y rellena con valores reales.
# El archivo `.env` está en .gitignore — NUNCA lo commitees.

# --- LLM (Claude) ---
# Llave de API de Anthropic. Obtenla en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Modelo de Claude a usar para drafting / entrevista
CLAUDE_MODEL=claude-opus-4-7

# --- Persistencia ---
# Path local de la base SQLite (relativo a la raíz del proyecto).
# Al migrar a EC2: cambiar a connection string de PostgreSQL.
DATABASE_URL=sqlite:///data/documente.db

# Path local donde se guardan los .docx exportados.
# Al migrar a EC2: cambiar a un bucket S3.
EXPORTS_PATH=data/exports

# --- App ---
# Identificador del usuario actual (en MVP single-user, siempre "default").
# Al migrar a multi-usuario: viene del sistema de auth.
USER_ID=default

# Nivel de logging (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
